# Which provider the labs should call through - flip this one value to
# switch every notebook from Claude/Bedrock to GPT-4o/Azure OpenAI.
# azure_openai or bedrock
PROVIDER=azure_openai

# --- Amazon Bedrock (development phase) ---
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# AWS credentials are picked up from the standard AWS credential chain
# (aws configure / AWS_ACCESS_KEY_ID+AWS_SECRET_ACCESS_KEY / SSO profile).

# --- Azure OpenAI (later migration target) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
